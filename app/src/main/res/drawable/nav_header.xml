<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#4CAF50"
    android:padding="16dp">

    <!-- Profile Picture -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="64dp"
        android:layout_height="64dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="12dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/outline_person_24"
            android:scaleType="centerCrop"
            android:contentDescription="Profile Picture"
            android:tint="#4CAF50"
            android:background="#FFFFFF"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- User Name -->
    <TextView
        android:id="@+id/tvNavUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alex Johnson"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"/>

    <!-- User Email -->
    <TextView
        android:id="@+id/tvNavUserEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="alex.johnson@example.com"
        android:textColor="#E8F5E8"
        android:textSize="14sp"
        android:layout_marginTop="4dp"/>

    <!-- User Points -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/outline_star_24"
            android:tint="#FFD700"
            android:contentDescription="Points"/>
        <TextView
            android:id="@+id/tvNavUserPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1250 Points"
            android:textColor="#FFD700"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#80FFFFFF"
        android:layout_marginVertical="16dp" />

    <!-- ========== STATS SECTION ========== -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Stats"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Stats Row (Trades, Rating, Skills) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <!-- Trades -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/nav_trades_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trades"
                android:textColor="#E8F5E8"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#80FFFFFF" />

        <!-- Rating -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/nav_rating_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rating"
                android:textColor="#E8F5E8"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#80FFFFFF" />

        <!-- Skills -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/nav_skills_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skills"
                android:textColor="#E8F5E8"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
    

</LinearLayout>