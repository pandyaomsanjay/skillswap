<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/border_rounded"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Video"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnRemoveVideo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/baseline_delete_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Remove video" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Video Title"
        android:layout_marginTop="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/ettVideoTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Video Description">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/ettVideoDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Credits: "
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/VideoDecrement"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/baseline_remove_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Decrease credits" />

        <TextView
            android:id="@+id/tvvVideoCredits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp" />

        <ImageButton
            android:id="@+id/VideoIncrement"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/outline_add_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Increase credits" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/SelectVideoFile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Video"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:backgroundTint="#4CAF50" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvVideoFileName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No video selected"
        android:textColor="#757575"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <ProgressBar
        android:id="@+id/progressVideoUpload"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:visibility="gone"
        android:layout_marginTop="4dp" />
</LinearLayout>