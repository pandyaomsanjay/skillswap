<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1437"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- ═══════════════════════════════════════
             HERO HEADER
        ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="56dp"
            android:paddingBottom="32dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:background="#050D2E">

            <!-- Icon ring -->
            <FrameLayout
                android:id="@+id/iconBox"
                android:layout_width="82dp"
                android:layout_height="82dp"
                android:layout_marginBottom="18dp">

                <!-- Outer faint ring -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="41dp"
                    app:cardBackgroundColor="#00000000"
                    app:strokeColor="#402B3A7A"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp" />

                <!-- Inner icon circle -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="66dp"
                    android:layout_height="66dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="33dp"
                    app:cardBackgroundColor="#121D50"
                    app:strokeColor="#4F63E8"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/logo2"
                        android:scaleType="centerCrop"
                        android:contentDescription="@null" />

                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Verify Your Email"
                android:textColor="#EEF2FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvEmailInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTP sent to your email"
                android:textColor="#9AAAE8"
                android:textSize="14sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════
             MAIN CARD
        ═══════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="#0B1437"
            app:strokeColor="#2B3A7A"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Section label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="ENTER 6-DIGIT CODE"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:textColor="#8C9EFF"
                    android:layout_marginBottom="20dp" />

                <!-- OTP Boxes -->
                <LinearLayout
                    android:id="@+id/otpBoxesContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- OTP Box 1 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOtp1"
                        android:layout_width="44dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#121D50"
                        app:strokeColor="#2B3A7A"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp">
                        <EditText
                            android:id="@+id/otp1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#EEF2FF"
                            android:cursorVisible="false"
                            android:background="@android:color/transparent"
                            android:padding="0dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- OTP Box 2 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOtp2"
                        android:layout_width="44dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#121D50"
                        app:strokeColor="#2B3A7A"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp">
                        <EditText
                            android:id="@+id/otp2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#EEF2FF"
                            android:cursorVisible="false"
                            android:background="@android:color/transparent"
                            android:padding="0dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- OTP Box 3 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOtp3"
                        android:layout_width="44dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#121D50"
                        app:strokeColor="#2B3A7A"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp">
                        <EditText
                            android:id="@+id/otp3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#EEF2FF"
                            android:cursorVisible="false"
                            android:background="@android:color/transparent"
                            android:padding="0dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- OTP Box 4 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOtp4"
                        android:layout_width="44dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#121D50"
                        app:strokeColor="#2B3A7A"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp">
                        <EditText
                            android:id="@+id/otp4"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#EEF2FF"
                            android:cursorVisible="false"
                            android:background="@android:color/transparent"
                            android:padding="0dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- OTP Box 5 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOtp5"
                        android:layout_width="44dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#121D50"
                        app:strokeColor="#2B3A7A"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp">
                        <EditText
                            android:id="@+id/otp5"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#EEF2FF"
                            android:cursorVisible="false"
                            android:background="@android:color/transparent"
                            android:padding="0dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- OTP Box 6 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOtp6"
                        android:layout_width="44dp"
                        android:layout_height="54dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#121D50"
                        app:strokeColor="#2B3A7A"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp">
                        <EditText
                            android:id="@+id/otp6"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#EEF2FF"
                            android:cursorVisible="false"
                            android:background="@android:color/transparent"
                            android:padding="0dp" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Timer Pill -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/timerPill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#050D2E"
                    app:strokeColor="#2B3A7A"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/tvTimerLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Expires in "
                            android:textSize="12sp"
                            android:textColor="#7A8EC7" />

                        <TextView
                            android:id="@+id/tvTimer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10:00"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#8C9EFF"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Verify Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerify"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Verify OTP"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#EEF2FF"
                    app:cornerRadius="14dp"
                    app:backgroundTint="#4F63E8"
                    android:layout_marginBottom="16dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1B2660"
                    android:layout_marginBottom="16dp" />

                <!-- Error message -->
                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:textSize="12sp"
                    android:textColor="#8E1919"
                    android:visibility="gone"
                    android:text="Invalid or expired OTP"
                    android:layout_marginBottom="8dp" />

                <!-- Resend row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Didn't receive? "
                        android:textColor="#7A8EC7"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvResend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resend OTP"
                        android:textColor="#6979F8"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Security note -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒 "
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Secured with end-to-end encryption"
                        android:textColor="#2B3A7A"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Progress spinner -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:indeterminateTint="#4F63E8"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
