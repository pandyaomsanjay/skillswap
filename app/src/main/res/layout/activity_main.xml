<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B2C3D"
    android:gravity="center"
    tools:context=".MainActivity">

    <!-- Logo Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- App Logo (larger for emphasis) -->
        <ImageView
            android:id="@+id/imageView"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/logo2"
            android:contentDescription="SkillSwap Logo"
            android:scaleType="fitCenter"
            android:elevation="4dp" />

        <!-- App Name (keep if logo doesn't include text; otherwise set visibility="gone") -->
        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SkillSwap"
            android:textColor="@android:color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-medium"
            android:visibility="visible" />  <!-- Change to "gone" if logo already has text -->

        <!-- Tagline (slightly smaller and lighter) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trade Skills, Share Knowledge"
            android:textColor="#E8F5E8"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.03" />

    </LinearLayout>

    <!-- Loading Indicator (centered below) -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="48dp"
        android:indeterminate="true"
        app:indicatorColor="@android:color/white"
        app:trackColor="#E8F5E8"
        android:elevation="2dp" />

    <!-- Loading Text (optional, can be removed) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textColor="#E8F5E8"
        android:textSize="14sp"
        android:layout_marginTop="12dp"
        android:visibility="gone" />  <!-- Hide loading text if not needed -->

</LinearLayout>