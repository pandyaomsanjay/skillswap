<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0B2C3D"
    tools:context=".MainActivity">

    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:animateLayoutChanges="true">

        <!-- Card Container -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="32dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="#E8FFFFFF"
            android:layout_margin="24dp"
            app:cardPreventCornerOverlap="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <!-- Circular Logo Container -->
                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="70dp"
                    app:cardElevation="12dp">

                    <ImageView
                        android:id="@+id/imageView"
                        android:layout_width="241dp"
                        android:layout_height="193dp"
                        android:layout_gravity="center"
                        android:contentDescription="SkillSwap Logo"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/logo2" />

                </androidx.cardview.widget.CardView>

                <!-- App Name -->
                <TextView
                    android:id="@+id/appName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-black"
                    android:shadowColor="#20000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="4"
                    android:text="SkillSwap"
                    android:textColor="#1A5F7A"
                    android:textSize="40sp"
                    android:textStyle="bold" />

                <!-- Tagline -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.05"
                    android:text="✦ Trade Skills, Share Knowledge ✦"
                    android:textColor="#2C7DA0"
                    android:textSize="13sp" />

                <!-- Colored Divider -->
                <View
                    android:layout_width="80dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:background="#2C7DA0" />

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-light"
                    android:text="Connect &amp; Grow Together"
                    android:textColor="#4A90A4"
                    android:textSize="12sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Loading Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <!-- Simple ProgressBar (works on all Android versions) -->
            <ProgressBar
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:indeterminate="true"
                android:indeterminateTint="#61A5C2"
                android:indeterminateTintMode="src_in"
                android:elevation="2dp" />

            <!-- Loading Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please wait..."
                android:textColor="#E8F5E8"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.08" />

            <!-- Loading Dots -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● ● ●"
                android:textColor="#80FFFFFF"
                android:textSize="8sp"
                android:layout_marginTop="6dp"
                android:alpha="0.7" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
